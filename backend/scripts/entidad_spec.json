{
  "tabla": "Entidades",
  "descripcion": "Catálogo de entidades (clientes y proveedores) con configuración de cuenta corriente",
  "campos": [
    { "columna": "Id",                 "tipo": "INT",               "pk": true, "autoIncrement": true, "nulleable": false, "descripcion": "Identificador único" },
    { "columna": "Tipo",               "tipo": "VARCHAR(20)",       "pk": false, "nulleable": false, "descripcion": "Tipo de entidad: clientes | proveedores" },
    { "columna": "Nro",                "tipo": "INT",               "pk": false, "nulleable": false, "descripcion": "Número correlativo por Tipo + OrganizacionId" },
    { "columna": "Nombre",             "tipo": "VARCHAR(200)",      "pk": false, "nulleable": false, "descripcion": "Denominación / Razón social" },
    { "columna": "Telefono",           "tipo": "VARCHAR(50)",       "pk": false, "nulleable": true,  "descripcion": "Teléfono de contacto" },
    { "columna": "Cuit",               "tipo": "VARCHAR(20)",       "pk": false, "nulleable": true,  "descripcion": "CUIT / CUIL" },
    { "columna": "Saldo",              "tipo": "DECIMAL(18,2)",     "pk": false, "nulleable": true,  "default": "0.00", "descripcion": "Saldo contable general" },
    { "columna": "CtaCteHabilitado",   "tipo": "TINYINT(1)",        "pk": false, "nulleable": true,  "default": "0", "descripcion": "1 = gestión de cuenta corriente habilitada" },
    { "columna": "CtaCteImporteMaximo","tipo": "DECIMAL(18,2)",     "pk": false, "nulleable": true,  "descripcion": "Límite máximo de saldo en Cta Cte" },
    { "columna": "CtaCtePlazoDias",    "tipo": "INT",               "pk": false, "nulleable": true,  "descripcion": "Plazo en días para vencimiento" },
    { "columna": "Activo",             "tipo": "TINYINT(1)",        "pk": false, "nulleable": true,  "default": "1", "descripcion": "Baja lógica" },
    { "columna": "OrganizacionId",     "tipo": "INT",               "pk": false, "nulleable": false, "descripcion": "FK a Organizaciones" },
    { "columna": "SucursalId",         "tipo": "INT",               "pk": false, "nulleable": true,  "descripcion": "FK a Sucursales" },
    { "columna": "FechaAlta",          "tipo": "TIMESTAMP",         "pk": false, "nulleable": true,  "default": "CURRENT_TIMESTAMP", "descripcion": "Fecha de creación" }
  ],
  "indices": [
    { "nombre": "Idx_Entidades_Tipo",         "columnas": ["Tipo"] },
    { "nombre": "Idx_Entidades_Activo",       "columnas": ["Activo"] },
    { "nombre": "Idx_Entidades_Organizacion", "columnas": ["OrganizacionId"] },
    { "nombre": "Idx_Entidades_Sucursal",     "columnas": ["SucursalId"] }
  ],
  "crud": {
    "obtenerTodos": {
      "procedure": "SpEntidades_ObtenerTodos",
      "parametros": [
        { "nombre": "pTipo",           "tipo": "VARCHAR(20)", "mapa": "Tipo" },
        { "nombre": "pSoloActivos",    "tipo": "TINYINT",     "mapa": "Activo" },
        { "nombre": "pOrganizacionId", "tipo": "INT",         "mapa": "OrganizacionId" },
        { "nombre": "pSucursalId",     "tipo": "INT",         "mapa": "SucursalId" }
      ],
      "returns": "JSON_ARRAY de entidades"
    },
    "obtenerPorId": {
      "procedure": "SpEntidades_ObtenerPorId",
      "parametros": [
        { "nombre": "pId",             "tipo": "INT", "mapa": "Id" },
        { "nombre": "pOrganizacionId", "tipo": "INT", "mapa": "OrganizacionId" }
      ],
      "returns": "JSON_OBJECT de entidad"
    },
    "crear": {
      "procedure": "SpEntidades_Crear",
      "parametros": [
        { "nombre": "pTipo",                "tipo": "VARCHAR(20)",   "requerido": true,  "mapa": "Tipo" },
        { "nombre": "pNombre",              "tipo": "VARCHAR(200)",  "requerido": true,  "mapa": "Nombre" },
        { "nombre": "pTelefono",            "tipo": "VARCHAR(50)",   "requerido": false, "mapa": "Telefono" },
        { "nombre": "pCuit",                "tipo": "VARCHAR(20)",   "requerido": false, "mapa": "Cuit" },
        { "nombre": "pSaldo",               "tipo": "DECIMAL(18,2)", "requerido": false, "mapa": "Saldo" },
        { "nombre": "pOrganizacionId",      "tipo": "INT",           "requerido": true,  "mapa": "OrganizacionId" },
        { "nombre": "pSucursalId",          "tipo": "INT",           "requerido": false, "mapa": "SucursalId" },
        { "nombre": "pCtaCteHabilitado",    "tipo": "TINYINT(1)",    "requerido": false, "mapa": "CtaCteHabilitado" },
        { "nombre": "pCtaCteImporteMaximo", "tipo": "DECIMAL(18,2)", "requerido": false, "mapa": "CtaCteImporteMaximo" },
        { "nombre": "pCtaCtePlazoDias",     "tipo": "INT",           "requerido": false, "mapa": "CtaCtePlazoDias" }
      ],
      "returns": "{ id, nro }"
    },
    "actualizar": {
      "procedure": "SpEntidades_Actualizar",
      "parametros": [
        { "nombre": "pId",                  "tipo": "INT",           "requerido": true,  "mapa": "Id" },
        { "nombre": "pNombre",              "tipo": "VARCHAR(200)",  "requerido": false, "mapa": "Nombre" },
        { "nombre": "pTelefono",            "tipo": "VARCHAR(50)",   "requerido": false, "mapa": "Telefono" },
        { "nombre": "pCuit",                "tipo": "VARCHAR(20)",   "requerido": false, "mapa": "Cuit" },
        { "nombre": "pSaldo",               "tipo": "DECIMAL(18,2)", "requerido": false, "mapa": "Saldo" },
        { "nombre": "pOrganizacionId",      "tipo": "INT",           "requerido": true,  "mapa": "OrganizacionId" },
        { "nombre": "pSucursalId",          "tipo": "INT",           "requerido": false, "mapa": "SucursalId" },
        { "nombre": "pCtaCteHabilitado",    "tipo": "TINYINT(1)",    "requerido": false, "mapa": "CtaCteHabilitado" },
        { "nombre": "pCtaCteImporteMaximo", "tipo": "DECIMAL(18,2)", "requerido": false, "mapa": "CtaCteImporteMaximo" },
        { "nombre": "pCtaCtePlazoDias",     "tipo": "INT",           "requerido": false, "mapa": "CtaCtePlazoDias" }
      ],
      "returns": "{ id }"
    },
    "eliminar": {
      "procedure": "SpEntidades_Eliminar",
      "parametros": [
        { "nombre": "pId",             "tipo": "INT", "requerido": true, "mapa": "Id" },
        { "nombre": "pOrganizacionId", "tipo": "INT", "requerido": true, "mapa": "OrganizacionId" }
      ],
      "returns": "{ id }"
    }
  }
}
